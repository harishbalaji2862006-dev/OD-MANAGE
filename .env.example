# College OD & Attendance Manager - Environment Configurations

# 1. Supabase Settings
# Retrieve these from your Supabase Dashboard -> Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# 2. Portal Scraping Proxy Settings (Optional)
# If you build a serverless scraping proxy for aims.rkmvc.ac.in, provide its URL here:
VITE_PORTAL_SCRAPE_API=https://your-netlify-endpoint.netlify.app/.netlify/functions/scrape
